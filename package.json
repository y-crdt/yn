{
  "name": "@y-crdt/yn",
  "version": "0.1.2",
  "description": "nodejs bindings to yrs",
  "main": "./load.cjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./load.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "load.cjs",
    "index.mjs",
    "index.d.ts",
    "index-*.node",
    "README.md"
  ],
  "scripts": {
    "test": "cargo test",
    "cargo-build": "cargo build --message-format=json-render-diagnostics > cargo.log",
    "cross-build": "cross build --message-format=json-render-diagnostics > cross.log",
    "postcargo-build": "neon dist < cargo.log",
    "postcross-build": "neon dist -m /target < cross.log",
    "debug": "npm run cargo-build --",
    "build": "npm run cargo-build -- --release",
    "cross": "npm run cross-build -- --release",
    "bench": "npm --prefix benchmark install && node benchmark/bench.js"
  },
  "author": "Bartosz Sypytkowski",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/y-crdt/yn.git"
  },
  "keywords": [
    "y-crdt",
    "yjs",
    "yrs",
    "rust"
  ],
  "type": "module",
  "devDependencies": {
    "@neon-rs/cli": "0.1.82"
  }
}
